# Frontend ↔ Backend wiring.
#
# Backend and frontend live on different VPS hosts. The browser will talk
# DIRECTLY to the backend host, so VITE_API_URL must be reachable from the
# user's browser (public hostname + HTTPS in prod).
#
#   dev:    VITE_API_URL=http://localhost:8000
#   stage:  VITE_API_URL=https://api.staging.example.com
#   prod:   VITE_API_URL=https://api.example.com
#
# The backend must also return matching CORS headers for the frontend
# origin — see backend/src/api/main.py if you need to widen the list.
VITE_API_URL=http://localhost:8000

# Only used by `vite dev` proxy. Unused in production builds.
VITE_DEV_PROXY=http://localhost:8000

# Cloudflare Turnstile — public site key (Phase 7).
# Get one at: Cloudflare Dashboard → Turnstile → Add site.
# Leave empty to disable captcha widget on /signup and /login (only
# valid combined with backend DISABLE_CAPTCHA=1).
VITE_TURNSTILE_SITE_KEY=

# ── Production nginx (docker build + compose.prod.yml) ────────
# Домен фронта — используется nginx/entrypoint.sh при рендере
# конфигов и certbot для выпуска TLS.
WEB_DOMAIN=web.example.com
CERTBOT_EMAIL=ops@example.com
CERTBOT_STAGING=0
# Origin'ы, куда фронт делает fetch(). Должен совпадать с API_DOMAIN бэка
# (иначе CSP заблокирует запросы).
CSP_CONNECT_SRC=https://api.example.com
